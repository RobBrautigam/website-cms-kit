# Website CMS Kit — environment variables
# Copy to .env.local for development; set these in your host dashboard for prod.
# NEVER commit real values. Only NEXT_PUBLIC_* vars are exposed to the browser.

# --- Supabase (required) ---
# Project URL + anon key are public by design (the anon key ships in the client
# bundle; Row-Level Security protects the data).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Service-role key — SERVER ONLY. Bypasses RLS (admin god mode). Used by the
# admin API routes, the audit writer, and requireAdmin()'s role lookup.
# NEVER expose this to the browser or the CI build environment.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Optional ---
# Only needed if you use the /api/ai/* content-generation routes.
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# Absolute site URL, for building links. Optional.
NEXT_PUBLIC_SITE_URL=https://your-domain.com
